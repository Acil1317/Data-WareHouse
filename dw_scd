SET end_date = '2024-12-31', is_current = FALSE
WHERE customer_id = 'C001' AND is_current = TRUE;

-- Langkah 2: Masukkan record baru dengan status member yang baru
INSERT INTO dim_customer_s2 (customer_id, nama, kota, status_member, start_date, end_date, is_current)
VALUES ('C001', 'Budi', 'Bandung', 'Gold', '2025-01-01', '9999-12-31', TRUE);

-- type 3
CREATE TABLE dim_customer_s3 (
    customer_id VARCHAR(50) PRIMARY KEY,
    nama VARCHAR(100),
    kota_current VARCHAR(100),
    kota_previous VARCHAR(100),
    status_member_current VARCHAR(50),
    status_member_previous VARCHAR(50)
);
-- Tahun 2023: Data Awal
INSERT INTO dim_customer_s3 (customer_id, nama, kota_current, kota_previous, status_member_current, status_member_previous)
VALUES ('C001', 'Budi', 'Jakarta', NULL, 'Silver', NULL);

-- Tahun 2024: Budi pindah ke Bandung
-- Pindahkan data kota_current ke kota_previous, lalu isi kota_current dengan yang baru
UPDATE dim_customer_s3
SET kota_previous = kota_current,
    kota_current = 'Bandung'
WHERE customer_id = 'C001';

-- Tahun 2025: Status berubah menjadi Gold
-- Pindahkan data status_current ke status_previous, lalu isi status_current dengan yang baru
UPDATE dim_customer_s3
SET status_member_previous = status_member_current,
    status_member_current = 'Gold'
WHERE customer_id = 'C001';

