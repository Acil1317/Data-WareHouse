-- type 2
CREATE TABLE dim_customer_s2 (
    customer_key SERIAL PRIMARY KEY, -- Surrogate key (ID unik untuk tiap baris)
    customer_id VARCHAR(50),         -- Natural key (ID pelanggan tetap)
    nama VARCHAR(100),
    kota VARCHAR(100),
    status_member VARCHAR(50),
    start_date DATE,
    end_date DATE,
    is_current BOOLEAN
);
-- Tahun 2023: Data Awal
INSERT INTO dim_customer_s2 (customer_id, nama, kota, status_member, start_date, end_date, is_current)
VALUES ('C001', 'Budi', 'Jakarta', 'Silver', '2023-01-01', '9999-12-31', TRUE);

-- Tahun 2024: Perubahan Kota ke Bandung
-- Langkah 1: Nonaktifkan record yang saat ini aktif
UPDATE dim_customer_s2
SET end_date = '2023-12-31', is_current = FALSE
WHERE customer_id = 'C001' AND is_current = TRUE;

-- Langkah 2: Masukkan record baru dengan kota yang baru
INSERT INTO dim_customer_s2 (customer_id, nama, kota, status_member, start_date, end_date, is_current)
VALUES ('C001', 'Budi', 'Bandung', 'Silver', '2024-01-01', '9999-12-31', TRUE);

-- Tahun 2025: Perubahan Status Member ke Gold
-- Langkah 1: Nonaktifkan record yang saat ini aktif
